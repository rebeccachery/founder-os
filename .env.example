# Database
DATABASE_PATH=storage/founder_os.db
SEED_DEMO_DATA=true

# API
API_KEY=dev-local-key
CORS_ORIGINS=http://localhost:3000

# Search providers (at least one recommended)
TAVILY_API_KEY=
SERPAPI_KEY=
GOOGLE_CSE_KEY=
GOOGLE_CSE_CX=

# Comma-separated fallback order when no provider specified
SEARCH_FALLBACK_ORDER=tavily,serpapi,google_cse

# OSS Discovery (optional — improves API rate limits)
GITHUB_TOKEN=
HF_TOKEN=
OSS_DISCOVERY_MAX_PER_QUERY=10

# Social agent — Your Company product repos (optional path overrides)
PRODUCT_REPO_PATH=../your-product-repo
NYC_MAP_PATH=../nyc-map
DEMO_REPO_PATH=../your-product-demo
# GITHUB_TOKEN required for private your-product-repo when local clone unavailable

# LLM content generation (optional — template fallback when provider unavailable)
# Local OSS default: Ollama (brew install ollama && ollama pull qwen2.5:7b)
OLLAMA_BASE_URL=http://localhost:11434/v1
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:7b
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
