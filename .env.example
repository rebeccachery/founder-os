# Database
DATABASE_PATH=storage/founder_os.db
SEED_DEMO_DATA=true

# API
API_KEY=dev-local-key
CORS_ORIGINS=http://localhost:3000

# Search providers (at least one recommended)
TAVILY_API_KEY=
SERPAPI_KEY=
GOOGLE_CSE_KEY=
GOOGLE_CSE_CX=

# Comma-separated fallback order when no provider specified
SEARCH_FALLBACK_ORDER=tavily,serpapi,google_cse

# OSS Discovery (optional — improves API rate limits)
GITHUB_TOKEN=
HF_TOKEN=
OSS_DISCOVERY_MAX_PER_QUERY=10
